{
  "$schema": "https://raw.githubusercontent.com/nicerdicer/tauri-v2-schema/main/tauri.conf.json",
  "productName": "MAM Podcast Studio",
  "version": "1.0.0",
  "identifier": "com.modernancestralmamas.podcast-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MAM Podcast Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": {
        "db": "sqlite:mam_podcast_studio.db"
      }
    },
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "ffmpeg",
          "sidecar": true,
          "args": true
        },
        {
          "name": "ffprobe",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "fs": {
      "scope": {
        "allow": [
          "$APPDATA/**",
          "$HOME/**",
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$VIDEO/**",
          "$AUDIO/**"
        ]
      }
    },
    "dialog": {
      "open": true,
      "save": true
    }
  }
}
